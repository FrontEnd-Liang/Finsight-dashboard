DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# Use deepseek-v4-flash for lower latency
DEEPSEEK_CONTEXT_WINDOW=128000
CHAT_MAX_TOKENS=2048
RAG_TOP_K=3

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Embeddings (use OpenAI key if DeepSeek does not support embeddings)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# Corpus refinement on downvotes (NOT DeepSeek — e.g. SiliconFlow Qwen)
REFINEMENT_API_KEY=
REFINEMENT_BASE_URL=https://api.siliconflow.cn/v1
REFINEMENT_MODEL=Qwen/Qwen2.5-72B-Instruct

CORS_ORIGINS=http://localhost:3000
